<?xml version="1.0"?>
<robot name="turtlebot3_burger" xmlns:xacro="http://ros.org/wiki/xacro">

  <xacro:arg name="laser_visual" default="false"/>

  <xacro:property name="base_mesh_file" value="package://turtlebot3_description/meshes/bases/burger_base.stl"/>
  <xacro:property name="wheel_mesh_file" value="package://turtlebot3_description/meshes/wheels/left_tire.stl"/>

  <xacro:property name="wheel_radius" value="0.033"/>
  <xacro:property name="wheel_length" value="0.018"/>
  <xacro:property name="wheel_separation" value="0.160"/>
  <xacro:property name="wheel_separation_length" value="0.138"/>
  <xacro:property name="turning_radius" value="0.1435"/>
  <xacro:property name="robot_radius" value="0.105"/>
  <xacro:property name="caster_mass" value="0.01"/>
  <xacro:property name="caster_radius" value="0.009"/>

  <material name="black"><color rgba="0.0 0.0 0.0 1.0"/></material>
  <material name="dark"><color rgba="0.3 0.3 0.3 1.0"/></material>
  <material name="light_black"><color rgba="0.4 0.4 0.4 1.0"/></material>
  <material name="blue"><color rgba="0.1 0.2 0.8 1.0"/></material>
  <material name="green"><color rgba="0.1 0.8 0.2 1.0"/></material>
  <material name="grey"><color rgba="0.5 0.5 0.5 1.0"/></material>

  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0.0 0.0 0.010" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="-0.032 0 0.0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${base_mesh_file}" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="-0.032 0 0.070" rpy="0 0 0"/>
      <geometry>
        <box size="0.140 0.140 0.143"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.0 0.0 0.0"/>
      <mass value="0.825"/>
      <inertia ixx="1.307950e-03" ixy="0.000000e+00" ixz="0.000000e+00"
               iyy="1.307950e-03" iyz="0.000000e+00"
               izz="1.943920e-03"/>
    </inertial>
  </link>

  <joint name="wheel_left_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_left_link"/>
    <origin xyz="0.0 ${wheel_separation / 2} 0.023" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="wheel_left_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${wheel_mesh_file}" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="dark"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_length}"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.028"/>
      <inertia ixx="1.1175580e-05" ixy="0" ixz="0"
               iyy="9.7502924e-06" iyz="0"
               izz="9.7502924e-06"/>
    </inertial>
  </link>

  <joint name="wheel_right_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_right_link"/>
    <origin xyz="0.0 ${-wheel_separation / 2} 0.023" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="wheel_right_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 3.141592 0"/>
      <geometry>
        <mesh filename="${wheel_mesh_file}" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="dark"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_length}"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.028"/>
      <inertia ixx="1.1175580e-05" ixy="0" ixz="0"
               iyy="9.7502924e-06" iyz="0"
               izz="9.7502924e-06"/>
    </inertial>
  </link>

  <joint name="caster_back_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_back_link"/>
    <origin xyz="-0.081 0 -0.004" rpy="-1.5708 0 0"/>
  </joint>

  <link name="caster_back_link">
    <collision>
      <origin xyz="0.0 0.001 0.0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="${caster_mass}"/>
      <inertia ixx="0.0" ixy="0.0" ixz="0.0"
               iyy="0.0" iyz="0.0"
               izz="0.0"/>
    </inertial>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="-0.032 0 0.068" rpy="0 0 0"/>
  </joint>

  <link name="imu_link"/>

  <xacro:include filename="$(find hw2_u2210189)/urdf/turtlebot3_burger.gazebo.xacro" />
</robot>